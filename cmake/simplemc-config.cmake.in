@PACKAGE_INIT@

# simplemc build options
set(SIMPLEMC_USE_STD_RANGES @SIMPLEMC_USE_STD_RANGES@)
set(SIMPLEMC_USE_HDF5 @SIMPLEMC_USE_HDF5@)
set(SIMPLEMC_VERSION @PROJECT_VERSION@)

include(CMakeFindDependencyMacro)

# add simplemc's CMake package directory to the search path for dependencies
list(INSERT CMAKE_PREFIX_PATH 0 "${PACKAGE_PREFIX_DIR}")

# find dependencies
find_dependency(fmt)
find_dependency(Eigen3)
find_dependency(nlohmann_json)
if(NOT SIMPLEMC_USE_STD_RANGES)
    find_dependency(range-v3)
endif()
find_dependency(MPI)
if(SIMPLEMC_USE_HDF5)
    find_dependency(HDF5 COMPONENTS C)
    find_dependency(HighFive)
endif()

# remove the package prefix from the search path again
list(REMOVE_AT CMAKE_PREFIX_PATH 0)

include("${CMAKE_CURRENT_LIST_DIR}/simplemc-targets.cmake")

check_required_components(simplemc)
