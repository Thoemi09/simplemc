/**
 * @file
 * @brief Library details, config and build options.
 */

#ifndef SIMPLEMC_CONFIG_HPP
#define SIMPLEMC_CONFIG_HPP

// version
#define SIMPLEMC_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SIMPLEMC_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SIMPLEMC_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define SIMPLEMC_VERSION "@PROJECT_VERSION@"

// build options
#cmakedefine SIMPLEMC_WITH_HIGHFIVE
#cmakedefine SIMPLEMC_USE_STD_RANGES

#endif // SIMPLEMC_CONFIG_HPP
